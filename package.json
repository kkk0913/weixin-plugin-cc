{
  "name": "weixin-plugin-cc-cx",
  "version": "1.0.1",
  "description": "WeChat bridge for Claude Code and Codex",
  "license": "MIT",
  "type": "module",
  "bin": "./server.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts",
    "start": "bun install --no-summary && WEIXIN_SERVER_ROLE=daemon bun server.ts",
    "login": "bun weixin-cli.ts login",
    "relogin": "bun weixin-cli.ts relogin",
    "clear": "bun weixin-cli.ts clear",
    "status": "bun weixin-cli.ts status",
    "daemon": "bun weixin-cli.ts daemon",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.7.0",
    "typescript": "^5.8.0"
  }
}
