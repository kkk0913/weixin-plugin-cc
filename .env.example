# Weixin daemon state directory
WEIXIN_STATE_DIR=

# Claude local config directory used for .credentials.json and stats-cache.json
WEIXIN_CLAUDE_CONFIG_DIR=~/.claude-official

# Codex workspace and runtime options
WEIXIN_CODEX_CWD=
WEIXIN_CODEX_APPROVAL_POLICY=on-request
WEIXIN_CODEX_SANDBOX=workspace-write
WEIXIN_CODEX_COMMAND=codex
